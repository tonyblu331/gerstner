{
  "name": "gerstner",
  "version": "0.2.0",
  "description": "Gerstner layout system - one package, multiple surfaces",
  "license": "MIT",
  "bin": {
    "gerstner": "./dist/cli/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "development": "./src/css/index.css",
      "default": "./dist/css/index.css"
    },
    "./css": {
      "development": "./src/css/index.css",
      "default": "./dist/css/index.css"
    },
    "./tw4": {
      "development": "./src/tw4/index.css",
      "default": "./dist/tw4/index.css"
    },
    "./stride": {
      "development": "./src/stride/index.css",
      "default": "./dist/stride/index.css"
    },
    "./stride/snapshot": {
      "types": "./src/stride/snapshot.ts",
      "development": "./src/stride/snapshot.ts",
      "import": "./dist/stride/snapshot.mjs",
      "default": "./src/stride/snapshot.ts"
    },
    "./stride/debugManifest": {
      "types": "./src/stride/debugManifest.ts",
      "development": "./src/stride/debugManifest.ts",
      "import": "./dist/stride/debugManifest.mjs",
      "default": "./src/stride/debugManifest.ts"
    },
    "./layout": {
      "development": "./src/css/layout-only.css",
      "default": "./dist/css/layout-only.css"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack && npm run copy-css",
    "copy-css": "node -e \"require('fs').cpSync('src/css', 'dist/css', {recursive:true}); require('fs').cpSync('src/tw4', 'dist/tw4', {recursive:true}); require('fs').cpSync('src/stride', 'dist/stride', {recursive:true})\"",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "emit:manifest": "pnpm dlx tsx src/stride/emit-manifest.ts > src/stride/contract.manifest.json",
    "emit:helpers": "pnpm dlx tsx src/cli/lib/emit-helpers.ts > src/css/helpers.css",
    "emit:tw4": "pnpm dlx tsx src/cli/lib/emit-tw4.ts > src/tw4/helpers.css",
    "emit:debug": "pnpm dlx tsx src/cli/lib/emit-debug.ts > ../debug/src/labels.json",
    "emit:reference": "pnpm dlx tsx src/cli/lib/emit-reference.ts > src/reference-fixtures/metadata.json",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "tailwindcss": "catalog:"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  }
}
