{
  "name": "gerstner-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp fmt && vp lint && vp run test -r && vp run build -r",
    "dev": "vp run playground#dev",
    "preview:playground": "cd apps/playground && vp preview",
    "cli": "cd packages/gerstner && vp run build && node dist/cli/cli.js",
    "cli:build": "cd packages/gerstner && vp run build",
    "cli:test": "cd packages/gerstner && vp test",
    "prepare": "vp config",
    "sync": "syncpack fix",
    "sync:check": "syncpack lint",
    "test:stride": "cd packages/gerstner && vp test -- stride",
    "test:generator": "cd packages/gerstner && vp test -- generator",
    "test:manifest": "cd packages/gerstner && vp test -- manifest",
    "test:parity": "cd packages/gerstner && vp test -- parity",
    "test:cli": "cd packages/gerstner && vp test -- cli",
    "test:reference": "cd packages/gerstner && vp test -- reference",
    "test:visual": "vp test:e2e -- visual",
    "test:e2e:layout": "vp test:e2e -- layout",
    "test:e2e:debug": "vp test:e2e -- debug"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "syncpack": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0"
}
